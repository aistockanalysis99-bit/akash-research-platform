# Akash Research Platform — environment template.
# Copy to .env for local dev; set these as SECRETS in Render (never commit real values).

# --- Data + AI provider keys ---
FMP_API_KEY=your_fmp_premium_key
UW_API_KEY=your_unusual_whales_key
GOOGLE_API_KEY=your_google_genai_key
ANTHROPIC_API_KEY=your_anthropic_key

# --- Telegram delivery ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Scheduler ---
ENABLE_SCHEDULER=true
SCHEDULER_TIMEZONE=America/New_York
SCHEDULER_MORNING_HOUR=8
SCHEDULER_MORNING_MINUTE=0
SCHEDULER_EVENING_HOUR=16
SCHEDULER_EVENING_MINUTE=30
SCHEDULER_EVENING_GAP_SECS=60

# --- API host/port (local dev). On Render, uvicorn binds $PORT via the start command. ---
API_HOST=127.0.0.1
API_PORT=8001
LOG_LEVEL=INFO

# --- Storage paths ---
# Local dev: leave as-is (relative to project dir).
# Render: point these at the mounted persistent disk (absolute paths).
DATA_CACHE_DIR=./data_cache
DB_PATH=./runs.sqlite
LOG_DIR=./logs
AI_RESEARCH_DIR=./ai_research
WATCHLIST_PROFILE_DIR=./watchlist
# Render example:
# DB_PATH=/var/data/runs.sqlite
# DATA_CACHE_DIR=/var/data/data_cache
# AI_RESEARCH_DIR=/var/data/ai_research
# WATCHLIST_PROFILE_DIR=/var/data/watchlist
# LOG_DIR=/var/data/logs
